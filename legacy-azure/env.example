# Configurações existentes do sistema CAGE SEFAZ-RS
OPENAI_API_KEY=your_openai_api_key
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_API_INSTANCE_NAME=iagenerativacageopenai
AZURE_OPENAI_BASE_ENDPOINT=""
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_API_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_ENDPOINT=your_embedding_endpoint
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=your_embeddings_deployment
AZURE_SEARCH_ENDPOINT=https://iagenerativacageaisearch.search.windows.net
AZURE_SEARCH_INDEX=rag-cagesefaz-01
AZURE_SEARCH_API_KEY=your_azure_search_api_key

# Configurações aprimoradas (novas)
# LLM-Judge - Sistema de avaliação automática de qualidade
ENABLE_LLM_JUDGE=true
JUDGE_QUALITY_THRESHOLD=0.6
JUDGE_CONFIDENCE_THRESHOLD=0.5

# Loop de Feedback - Sistema de melhoria contínua
ENABLE_FEEDBACK_LOOP=true
FEEDBACK_ANALYSIS_ENABLED=true

# Cache Inteligente
ENABLE_INTELLIGENT_CACHE=true
CACHE_MAX_SIZE=1000
CACHE_MAX_MEMORY_MB=100
CACHE_TTL_CIDADAO=1800000
CACHE_TTL_FUNCIONARIO=1200000
CACHE_TTL_GESTOR=600000
CACHE_TTL_USUARIO_SISTEMA=900000

# Métricas Avançadas
ENABLE_ADVANCED_METRICS=true
METRICS_COLLECTION_INTERVAL=60000
METRICS_RETENTION_DAYS=30

# Configurações gerais
NODE_ENV=development
LOG_LEVEL=info
NEXT_PUBLIC_APP_USE_AI_SEARCH_FILTER=false
