# ====================================
# Model-GPT Enterprise - AWS Configuration
# ====================================
#
# Copie este arquivo para .env e preencha com suas configurações reais
# cp .env.example .env
#

# —————————————————————————————————————
# AWS Configuration
# —————————————————————————————————————

# AWS Region onde seus serviços estão localizados
AWS_REGION=us-east-1

# —————————————————————————————————————
# Amazon Bedrock Configuration
# —————————————————————————————————————

# Model ID para geração de respostas (Chat)
# Modelos disponíveis:
#   - anthropic.claude-3-sonnet-20240229-v1:0 (recomendado)
#   - anthropic.claude-3-haiku-20240307-v1:0 (mais rápido)
#   - anthropic.claude-3-opus-20240229-v1:0 (mais poderoso)
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Model ID para geração de embeddings
# Modelos disponíveis:
#   - amazon.titan-embed-text-v1 (1536 dimensions)
#   - amazon.titan-embed-text-v2:0 (1024 dimensions, recomendado)
AWS_BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# —————————————————————————————————————
# Amazon OpenSearch Configuration
# —————————————————————————————————————

# Endpoint do domínio OpenSearch (incluir protocolo https)
# Exemplo: https://my-domain.us-east-1.aoss.amazonaws.com
# Seu endpoint estará disponível após criar o domínio na AWS Console
AWS_OPENSEARCH_ENDPOINT=https://your-opensearch-endpoint.region.aoss.amazonaws.com

# Nome do índice onde será armazenado o índice vetorial
AWS_OPENSEARCH_INDEX=rag-index

# —————————————————————————————————————
# Amazon DynamoDB Configuration
# —————————————————————————————————————

# Nome da tabela DynamoDB para armazenar histórico de conversas
# A tabela será criada automaticamente se não existir
AWS_DYNAMODB_TABLE=EnterpriseGPT-Conversations

# —————————————————————————————————————
# Amazon S3 Configuration (Opcional)
# —————————————————————————————————————

# Bucket S3 para armazenar documentos e assets
AWS_S3_BUCKET=enterprise-gpt-assets

# —————————————————————————————————————
# Logging Configuration
# —————————————————————————————————————

# Nível de logging
# Valores: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# —————————————————————————————————————
# Application Environment
# —————————————————————————————————————

# Ambiente de execução
# Valores: development, production, staging
NODE_ENV=development

# Porta para executar o servidor (se usand Next.js)
PORT=3000
